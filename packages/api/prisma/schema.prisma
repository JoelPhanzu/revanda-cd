generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
  SUPER_ADMIN
}

enum ProductStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ShipmentProvider {
  PLATFORM
  VENDOR
}

enum MessageSender {
  CUSTOMER
  VENDOR
}

enum KYCStatus {
  PENDING
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum DocumentType {
  RCCM
  ID_NATIONAL
  TAX_NUMBER_CERT
  PROOF_ADDRESS
  COMPANY_PRESENTATION
  LEGAL_REP_ID
  LEGAL_REP_PHOTO
  LEGAL_REP_MANDATE
  BANK_CERTIFICATE
  COMMERCIAL_REGISTRATION
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  fullName     String
  role         UserRole  @default(CUSTOMER)
  isActive     Boolean   @default(true)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  vendorProfile                Vendor?
  orders                       Order[]
  reviews                      Review[]
  sentMessages                 Message[]             @relation("CustomerMessages")
  deletionRequestsMade         DeletionRequest[]     @relation("DeletionRequester")
  deletionRequestsApproved     DeletionRequest[]     @relation("DeletionApprover")
  modificationRequestsMade     ModificationRequest[] @relation("ModificationRequester")
  modificationRequestsApproved ModificationRequest[] @relation("ModificationApprover")
  auditLogsPerformed           AuditLog[]            @relation("AuditPerformer")
  approvalWorkflowsCreated     ApprovalWorkflow[]    @relation("WorkflowCreator")
}

model Vendor {
  id              String   @id @default(cuid())
  userId          String   @unique
  companyName     String
  taxNumber       String?
  subscriptionPlan String?
  isVerified      Boolean  @default(false)
  isDeleted       Boolean  @default(false)
  deletedAt       DateTime?
  deletedBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  products     Product[]
  orderItems   OrderItem[]
  payments     Payment[]
  shipments    Shipment[]
  vendorStats  VendorStats?
  messages     Message[]     @relation("VendorMessages")
  reviews      Review[]
  kycProfile   VendorKyc?
}

model VendorKyc {
  id                  String    @id @default(cuid())
  vendorId            String    @unique
  companyName         String
  rccmNumber          String
  taxNumber           String
  companyAddress      String
  businessPhone       String
  businessEmail       String
  bankAccountHolder   String
  bankAccountNumber   String
  bankCode            String
  status              KYCStatus @default(PENDING)
  submittedAt         DateTime?
  approvedAt          DateTime?
  rejectionReason     String?
  expiresAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  vendor              Vendor                  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  documents           KycDocument[]
  legalRepresentative KycLegalRepresentative?
  verifications       KycVerification[]

  @@map("VendorKYC")
}

model KycDocument {
  id                 String             @id @default(cuid())
  kycId              String
  type               DocumentType
  fileUrl            String
  fileName           String
  fileSize           Int
  mimeType           String
  uploadedAt         DateTime           @default(now())
  expiresAt          DateTime?
  verificationStatus VerificationStatus @default(PENDING)

  kyc VendorKyc @relation(fields: [kycId], references: [id], onDelete: Cascade)

  @@unique([kycId, type])
  @@map("KYCDocument")
}

model KycLegalRepresentative {
  id                String   @id @default(cuid())
  kycId             String   @unique
  fullName          String
  position          String
  phone             String
  email             String
  address           String
  nationalIdNumber  String
  photoUrl          String?
  idDocumentUrl     String?
  mandateDocumentUrl String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  kyc VendorKyc @relation(fields: [kycId], references: [id], onDelete: Cascade)

  @@map("KYCLegalRepresentative")
}

model KycVerification {
  id         String             @id @default(cuid())
  kycId      String
  status     VerificationStatus
  notes      String?
  verifiedBy String?
  verifiedAt DateTime?
  createdAt  DateTime           @default(now())

  kyc VendorKyc @relation(fields: [kycId], references: [id], onDelete: Cascade)

  @@map("KYCVerification")
}

model Category {
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  parentId   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  parent     Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryHierarchy")
  products   Product[]
}

model Product {
  id                String        @id @default(cuid())
  vendorId          String
  categoryId        String
  name              String
  description       String
  price             Decimal       @db.Decimal(12, 2)
  currency          String        @default("USD")
  validationStatus  ProductStatus @default(PENDING_APPROVAL)
  isPublished       Boolean       @default(false)
  stock             Int           @default(0)
  isDeleted         Boolean       @default(false)
  deletedAt         DateTime?
  deletedBy         String?
  colors            String[]      @default([])
  sizes             String[]      @default([])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  vendor      Vendor           @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category    Category         @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]
  orderItems  OrderItem[]
  reviews     Review[]
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  sku         String   @unique
  size        String?
  color       String?
  attributes  Json?
  price       Decimal? @db.Decimal(12, 2)
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
}

model Order {
  id           String      @id @default(cuid())
  customerId   String
  status       OrderStatus @default(PENDING)
  totalAmount  Decimal     @db.Decimal(12, 2)
  currency     String      @default("USD")
  isDeleted    Boolean     @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  customer   User       @relation(fields: [customerId], references: [id])
  items      OrderItem[]
  payments   Payment[]
  shipments  Shipment[]
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String
  variantId    String?
  vendorId     String
  quantity     Int
  unitPrice    Decimal  @db.Decimal(12, 2)
  subtotal     Decimal  @db.Decimal(12, 2)
  status       OrderStatus @default(PENDING)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  order    Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product  Product        @relation(fields: [productId], references: [id])
  variant  ProductVariant? @relation(fields: [variantId], references: [id])
  vendor   Vendor         @relation(fields: [vendorId], references: [id])
}

model Payment {
  id             String        @id @default(cuid())
  orderId         String
  vendorId        String
  amount          Decimal       @db.Decimal(12, 2)
  commissionAmount Decimal      @db.Decimal(12, 2)
  status          PaymentStatus @default(PENDING)
  providerRef     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendor      Vendor      @relation(fields: [vendorId], references: [id])
  commission  Commission?
}

model Commission {
  id         String   @id @default(cuid())
  paymentId  String   @unique
  rate       Decimal  @db.Decimal(5, 2)
  amount     Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model Shipment {
  id              String           @id @default(cuid())
  orderId          String
  vendorId         String
  provider         ShipmentProvider @default(PLATFORM)
  trackingNumber   String?
  status           String
  shippedAt        DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendor  Vendor @relation(fields: [vendorId], references: [id])
}

model VendorStats {
  id            String   @id @default(cuid())
  vendorId       String   @unique
  totalSales     Decimal  @db.Decimal(12, 2) @default(0)
  totalOrders    Int      @default(0)
  averageRating  Float    @default(0)
  totalReviews   Int      @default(0)
  updatedAt      DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model Message {
  id              String        @id @default(cuid())
  conversationId  String
  customerId      String
  vendorId        String
  sender          MessageSender
  content         String
  readAt          DateTime?
  createdAt       DateTime      @default(now())

  customer User   @relation("CustomerMessages", fields: [customerId], references: [id], onDelete: Cascade)
  vendor   Vendor @relation("VendorMessages", fields: [vendorId], references: [id], onDelete: Cascade)
}

model Review {
  id          String   @id @default(cuid())
  productId   String
  customerId  String
  vendorId    String
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer  User    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vendor    Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([productId, customerId])
}

model DeletionRequest {
  id              String   @id @default(cuid())
  entityType      String
  entityId        String
  requestedBy     String
  requestReason   String?
  status          String   @default("PENDING")
  approvedBy      String?
  rejectionReason String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requester User  @relation("DeletionRequester", fields: [requestedBy], references: [id], onDelete: Cascade)
  approver  User? @relation("DeletionApprover", fields: [approvedBy], references: [id])

  @@index([entityType, entityId])
  @@index([requestedBy])
  @@index([status])
}

model ModificationRequest {
  id              String   @id @default(cuid())
  entityType      String
  entityId        String
  fieldName       String
  oldValue        String?
  newValue        String
  requestedBy     String
  status          String   @default("PENDING")
  approvedBy      String?
  rejectionReason String?
  approvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requester User  @relation("ModificationRequester", fields: [requestedBy], references: [id], onDelete: Cascade)
  approver  User? @relation("ModificationApprover", fields: [approvedBy], references: [id])

  @@index([entityType, entityId])
  @@index([requestedBy])
  @@index([status])
}

model AuditLog {
  id            String   @id @default(cuid())
  action        String
  entityType    String
  entityId      String
  performedBy   String
  oldValues     String?
  newValues     String?
  metadata      String?
  ipAddress     String?
  userAgent     String?
  result        String   @default("SUCCESS")
  failureReason String?
  createdAt     DateTime @default(now())

  performer User @relation("AuditPerformer", fields: [performedBy], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([performedBy])
  @@index([createdAt])
}

model ApprovalWorkflow {
  id            String   @id @default(cuid())
  entityType    String
  entityId      String
  changeType    String
  currentStep   Int      @default(1)
  totalSteps    Int      @default(1)
  status        String   @default("PENDING")
  createdBy     String
  approvalChain String
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creator User @relation("WorkflowCreator", fields: [createdBy], references: [id], onDelete: Cascade)
}
